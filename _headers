# Netlify Headers - Security Configuration
# https://docs.netlify.com/routing/headers/

# Security Headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://www.google-analytics.com; frame-ancestors 'none'
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cache-Control: public, max-age=3600

# Prevent caching for sensitive pages
/admin/*
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  Pragma: no-cache

# Security.txt location
/.well-known/security.txt
  Content-Type: text/plain
  Cache-Control: max-age=86400

# API endpoints protection (if added later)
/api/*
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'none'
